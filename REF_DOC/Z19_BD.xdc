set_property PACKAGE_PIN AV28 [get_ports {IO_NAND_DQ[0]}]
set_property PACKAGE_PIN AM28 [get_ports {O_NAND_CE_N[0]}]
set_property PACKAGE_PIN AV26 [get_ports IO_NAND_DQS_P]
set_property PACKAGE_PIN BA28 [get_ports O_NAND_RE_P]
set_property PACKAGE_PIN BB24 [get_ports O_NAND_ALE]
set_property PACKAGE_PIN AP27 [get_ports O_NAND_CLE]
set_property PACKAGE_PIN AU24 [get_ports O_NAND_WE_N]
set_property PACKAGE_PIN AY24 [get_ports O_NAND_WP_N]
set_property IOSTANDARD LVCMOS18 [get_ports O_NAND_WP_N]
set_property IOSTANDARD LVCMOS18 [get_ports O_NAND_WE_N]
set_property IOSTANDARD LVCMOS18 [get_ports O_NAND_CLE]
set_property IOSTANDARD LVCMOS18 [get_ports O_NAND_ALE]
set_property IOSTANDARD DIFF_HSTL_I_18 [get_ports O_NAND_RE_P]
set_property IOSTANDARD DIFF_HSTL_I_18 [get_ports IO_NAND_DQS_P]
set_property IOSTANDARD LVDS [get_ports diff_clock_rtl_0_clk_p]


set_property IOSTANDARD LVCMOS18 [get_ports {I_NAND_RB_N[0]}]
set_property IOSTANDARD LVCMOS18 [get_ports {IO_NAND_DQ[7]}]
set_property IOSTANDARD LVCMOS18 [get_ports {IO_NAND_DQ[6]}]
set_property IOSTANDARD LVCMOS18 [get_ports {IO_NAND_DQ[5]}]
